        {
            "fieldname": "age",
            "fieldtype": "Int",
            "label": "Age",
            "read_only": 1
        },
        {
            "fieldname": "biological_sex",
            "fieldtype": "Select",
            "label": "Biological Sex",
            "options": "\nMale\nFemale",
            "reqd": 1,
            "description": "Required for eGFR calculation [cite: 37]"
        },
        {
            "fieldname": "section_vitals",
            "fieldtype": "Section Break",
            "label": "Vital Metrics"
        },
        {
            "fieldname": "intake_height_cm",
            "fieldtype": "Int",
            "label": "Height (cm)",
            "description": "Use whole numbers only [cite: 41]"
        },
        {
            "fieldname": "intake_weight_kg",
            "fieldtype": "Float",
            "label": "Weight (kg)"
        },
        {
            "fieldname": "bmi",
            "fieldtype": "Float",
            "label": "Calculated BMI",
            "read_only": 1,
            "description": "Formula: weight / (height/100)^2 [cite: 42]"
        },
        {
            "fieldname": "bmi_category",
            "fieldtype": "Data",
            "label": "BMI Category",
            "read_only": 1
        },
        {
            "fieldname": "weight_to_lose",
            "fieldtype": "Float",
            "label": "Kg to reach BMI 25",
            "read_only": 1,
            "description": "Visible to S2W staff only [cite: 46, 49]"
        },
        {
            "fieldname": "height_unit",
            "fieldtype": "Select",
            "label": "Height Unit",
            "options": "\nFeet/Inches\nCentimeters",
            "reqd": 1
        },
        {
            "fieldname": "height_feet",
            "fieldtype": "Int",
