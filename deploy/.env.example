# KoraFlow Production Environment Variables
# Copy to .env and fill in values before deploying.
# NEVER commit the .env file to source control.

# ---- Database ----
DB_ROOT_PASSWORD=     # MariaDB root password
DB_PASSWORD=          # Frappe DB user password

# ---- Redis ----
REDIS_PASSWORD=       # Redis auth password

# ---- Application ----
ENVIRONMENT=staging   # staging | production
ENCRYPTION_KEY=       # Fernet key for application-level encryption (see utils/crypto.py)
                      # Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---- Deployment Safety ----
ALLOW_PROD_MIGRATE=false  # Set to 'true' ONLY for approved schema migrations

# ---- GCP (for CI/CD - set as GitHub Repository Variables) ----
# GCP_PROJECT_ID=koraflow-dev  # Set in GitHub Settings > Variables
# GCP_REGION=us-central1       # Set in GitHub Settings > Variables
